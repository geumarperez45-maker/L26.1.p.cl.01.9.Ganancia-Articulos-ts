{
  "compilerOptions": {
    /* Configuración de Salida */
    "target": "ES6",                          
    "module": "ES6",                          
    "rootDir": "./src",                       
    "outDir": "./dist",                       
    "moduleResolution": "node",               
    
    /* Rigor y Seguridad */
    "strict": true,                           
    "noImplicitAny": true,                    
    "esModuleInterop": true,                  
    "skipLibCheck": true,                     
    "forceConsistentCasingInFileNames": true, 
    "removeComments": false                   
  },
  "include": ["src/**/*"],                    
  "exclude": ["node_modules"]                
}